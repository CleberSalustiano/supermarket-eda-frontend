{
  "name": "@supermarket/checkout-web",
  "private": true,
  "version": "0.1.0",
  "description": "Checkout frontend application.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4101",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4201",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "cy:run": "cypress run --config-file cypress.config.ts",
    "test:e2e": "npm run build && start-server-and-test preview http://127.0.0.1:4201 cy:run"
  },
  "dependencies": {
    "@supermarket/api-sdk": "0.1.0",
    "@supermarket/frontend-config": "0.1.0",
    "@supermarket/frontend-tenant": "0.1.0",
    "@supermarket/frontend-ui": "0.1.0",
    "@tanstack/react-query": "5.81.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.6.2"
  }
}
